{
  "lsp": {
    "emmet-language-server": {
      "settings": {
        "showSuggestionsAsSnippets": true,
        "languages": ["html", "css", "jsx", "tsx"],
      },
    },
  },
  "scrollbar": {
    "show": "auto",
  },
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": false,
  },
  "preview_tabs": {
    "enable_keep_preview_on_code_navigation": false,
  },
  "bottom_dock_layout": "contained",
  "use_system_window_tabs": false,
  "window_decorations": "client",
  "zoomed_padding": true,
  "pane_split_direction_horizontal": "down",
  "pane_split_direction_vertical": "left",
  "terminal": {
    "button": false,
  },
  "diagnostics": {
    "button": false,
  },
  "search": {
    "button": false,
  },
  "title_bar": {
    "show_onboarding_banner": false,
    "show_project_items": false,
  },
  "toolbar": {
    "quick_actions": false,
  },
  "debugger": {
    "button": false,
  },
  "status_bar": {
    "experimental.show": false,
    "active_encoding_button": "enabled",
    "cursor_position_button": false,
    "active_language_button": true,
  },
  "project_panel": {
    "dock": "right",
    "button": true,
    "hide_root": false,
    "indent_guides": {
      "show": "always",
    },
    "auto_fold_dirs": true,
    "starts_open": true,
    "auto_reveal_entries": true,
    "git_status": true,
    "folder_icons": true,
    "file_icons": true,
    "entry_spacing": "comfortable",
    "hide_gitignore": false,
  },
  "ui_font_size": 18.0,
  "buffer_font_size": 18.0,
  "buffer_font_family": ".SystemUIFont",
  "icon_theme": {
    "mode": "dark",
    "light": "Base Charmed Icons",
    "dark": "Base Charmed Icons",
  },
  "theme": {
    "mode": "dark",
    "light": "",
    "dark": "Adwaita Dark",
  },
  "theme_overrides": {
    "Adwaita Dark": {
      "scrollbar.thumb.background": "#00000000",
      "scrollbar.thumb.border": "#00000000",
      "scrollbar.track.background": "#00000000",
      "scrollbar.track.border": "#00000000",
      "border.variant": "#00000000",
      "border": "#00000000",
      "title_bar.background": "#1d1d1d",
      "panel.background": "#282524",
      "tab_bar.background": "#1d1d1d",
      "panel.overlay_background": "#1d1d1d",
      "background": "#1d1d1d",
      "editor.background": "#1d1d1d",
      "status_bar.background": "#1d1d1d",
      "toolbar.background": "#1d1d1d",
      "tab.active_background": "#1d1d1d",
      "tab.inactive_background": "#1d1d1d",
      "editor.gutter.background": "#1d1d1d",
    },
  },
}
